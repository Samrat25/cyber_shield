│   ├── pinata.py         # IPFS storage
│   ├── monitor.py        # System metrics
│   └── ml_detector.py    # Anomaly detection
├── cli.py                # Main CLI interface
├── mock_nodes.py         # Simulated peer nodes
├── .env                  # Configuration
└── requirements.txt
```
